{
    "name": "defi-quest-engine",
    "version": "1.0.0",
    "private": true,
    "description": "White-label mission/quest system for Solana dApps with Jupiter Mobile integration",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev --filter=@defi-quest/core",
        "dev:ui": "turbo run dev --filter=@defi-quest/ui-components",
        "dev:admin": "turbo run dev --filter=@defi-quest/admin-dashboard",
        "dev:play": "turbo run dev --filter=@defi-quest/player-portal",
        "test": "turbo run test",
        "test:bankrun": "ts-mocha -p ./tsconfig.json -t 1000000 tests/bankrun-test.ts",
        "lint": "turbo run lint",
        "clean": "rimraf packages/*/dist packages/*/.next"
    },
    "keywords": [
        "solana",
        "jupiter",
        "defi",
        "quests",
        "gamification",
        "web3"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@coral-xyz/anchor": "0.30.1",
        "@jup-ag/api": "^6.0.48",
        "@metaplex-foundation/mpl-core": "^1.7.0",
        "@metaplex-foundation/umi": "^1.5.1",
        "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
        "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.5",
        "@solana-mobile/wallet-adapter-mobile": "^2.2.5",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "anchor-bankrun": "^0.5.0",
        "chai": "^6.2.2",
        "mocha": "^11.7.5",
        "rimraf": "^5.0.5",
        "solana-bankrun": "^0.4.0",
        "ts-mocha": "^11.1.0",
        "ts-node": "^10.9.2",
        "turbo": "^2.7.5",
        "typescript": "^5.3.0"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "packageManager": "npm@10.0.0"
}