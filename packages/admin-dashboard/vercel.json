{
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "installCommand": "npm install",
    "functions": {
        "app/api/overseer/batch-generate/route.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/overseer/batch-generate",
            "schedule": "0 0 * * *"
        }
    ]
}