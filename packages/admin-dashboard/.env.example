# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Required for Auth)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: For server-side operations (not needed for basic auth)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==============================
# SETUP INSTRUCTIONS:
# ==============================
# 1. Go to https://supabase.com and create a free project
# 2. Navigate to Project Settings > API
# 3. Copy "Project URL" → NEXT_PUBLIC_SUPABASE_URL
# 4. Copy "anon public" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 5. Go to Authentication > Providers and enable Email provider
# 6. Create a user: Authentication > Users > Add user
# ==============================
